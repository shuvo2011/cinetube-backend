<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Verify New Email - CineTube</title>
		<style>
			* {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
			}

			body {
				font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
				background-color: #f4f4f4;
				color: #1a1a1a;
				padding: 40px 20px;
			}

			.container {
				max-width: 520px;
				margin: 0 auto;
				background-color: #ffffff;
				border-radius: 16px;
				overflow: hidden;
				border: 1px solid #e0e0e0;
			}

			.header {
				padding: 28px 40px 20px;
				text-align: center;
				border-bottom: 1px solid #f0f0f0;
			}

			.logo {
				font-size: 26px;
				font-weight: 500;
				letter-spacing: 1px;
			}

			.logo .cine {
				color: #1a1a1a;
			}
			.logo .tube {
				color: #e50914;
			}

			.tagline {
				margin-top: 6px;
				font-size: 11px;
				letter-spacing: 3px;
				text-transform: uppercase;
				color: #999999;
			}

			.body {
				padding: 32px 40px;
			}

			.body h2 {
				font-size: 18px;
				font-weight: 500;
				color: #1a1a1a;
				margin-bottom: 8px;
			}

			.desc {
				font-size: 14px;
				color: #666666;
				line-height: 1.7;
				margin-bottom: 28px;
			}

			.btn-wrapper {
				text-align: center;
				margin-bottom: 24px;
			}

			.btn {
				display: inline-block;
				background-color: #e50914;
				color: #ffffff;
				text-decoration: none;
				font-size: 15px;
				font-weight: 500;
				padding: 14px 36px;
				border-radius: 8px;
				letter-spacing: 0.5px;
			}

			.fallback {
				font-size: 12px;
				color: #aaaaaa;
				line-height: 1.6;
				margin-bottom: 24px;
				word-break: break-all;
			}

			.fallback a {
				color: #e50914;
				text-decoration: none;
			}

			.warning {
				border-left: 2px solid #d4a017;
				padding: 12px 16px;
				margin-bottom: 24px;
				background: #fdfbf5;
				border-radius: 0 8px 8px 0;
			}

			.warning p {
				font-size: 13px;
				color: #7a6010;
				margin: 0;
				line-height: 1.6;
			}

			.ignore-text {
				font-size: 13px;
				color: #aaaaaa;
				line-height: 1.6;
			}

			.footer {
				padding: 16px 40px;
				border-top: 1px solid #f0f0f0;
				text-align: center;
				background-color: #fafafa;
			}

			.footer p {
				font-size: 12px;
				color: #bbbbbb;
				line-height: 1.8;
			}

			.footer a {
				color: #e50914;
				text-decoration: none;
				font-weight: 500;
			}
		</style>
	</head>
	<body>
		<div class="container">
			<div class="header">
				<div class="logo"><span class="cine">Cine</span><span class="tube">Tube</span></div>
				<div class="tagline">Email Change Verification</div>
			</div>

			<div class="body">
				<h2>Verify your new email</h2>
				<p class="desc">
					A request was made to change your CineTube account email to <strong><%= newEmail %></strong>. Click the
					button below to confirm this change.
				</p>

				<div class="btn-wrapper">
					<a href="<%= url %>" class="btn">Verify New Email</a>
				</div>

				<p class="fallback">
					If the button doesn't work, copy and paste this link into your browser:<br />
					<a href="<%= url %>"><%= url %></a>
				</p>

				<div class="warning">
					<p>If you did not request this change, please ignore this email or contact support immediately.</p>
				</div>

				<p class="ignore-text">This link will expire shortly. Do not share it with anyone.</p>
			</div>

			<div class="footer">
				<p>
					&copy; <%= new Date().getFullYear() %> CineTube. All rights reserved.<br />
					<a href="#">Privacy Policy</a> &nbsp;·&nbsp; <a href="#">Terms of Service</a>
				</p>
			</div>
		</div>
	</body>
</html>
