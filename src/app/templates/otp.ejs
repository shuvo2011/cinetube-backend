<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Email Verification - CineTube</title>
		<style>
			* {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
			}

			body {
				font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
				background-color: #f4f4f4;
				color: #1a1a1a;
				padding: 40px 20px;
			}

			.container {
				max-width: 520px;
				margin: 0 auto;
				background-color: #ffffff;
				border-radius: 16px;
				overflow: hidden;
				border: 1px solid #e0e0e0;
			}

			.header {
				padding: 28px 40px 20px;
				text-align: center;
				border-bottom: 1px solid #f0f0f0;
			}

			.logo {
				font-size: 26px;
				font-weight: 500;
				letter-spacing: 1px;
			}

			.logo .cine {
				color: #1a1a1a;
			}
			.logo .tube {
				color: #e50914;
			}

			.tagline {
				margin-top: 6px;
				font-size: 11px;
				letter-spacing: 3px;
				text-transform: uppercase;
				color: #999999;
			}

			.body {
				padding: 32px 40px;
			}

			.body h2 {
				font-size: 18px;
				font-weight: 500;
				color: #1a1a1a;
				margin-bottom: 8px;
			}

			.desc {
				font-size: 14px;
				color: #666666;
				line-height: 1.7;
				margin-bottom: 28px;
			}

			.otp-box {
				background-color: #fafafa;
				border: 1px solid #e8e8e8;
				border-radius: 12px;
				text-align: center;
				padding: 24px 20px;
				margin-bottom: 24px;
			}

			.otp-label {
				font-size: 11px;
				text-transform: uppercase;
				letter-spacing: 2.5px;
				color: #aaaaaa;
				font-weight: 500;
				margin-bottom: 16px;
			}

			.otp-expiry {
				font-size: 13px;
				color: #999999;
				margin-top: 16px;
			}

			.otp-expiry span {
				color: #1a1a1a;
				font-weight: 500;
			}

			.warning {
				border-left: 2px solid #d4a017;
				padding: 12px 16px;
				margin-bottom: 24px;
				background: #fdfbf5;
				border-radius: 0 8px 8px 0;
			}

			.warning p {
				font-size: 13px;
				color: #7a6010;
				margin: 0;
				line-height: 1.6;
			}

			.ignore-text {
				font-size: 13px;
				color: #aaaaaa;
				line-height: 1.6;
			}

			.footer {
				padding: 16px 40px;
				border-top: 1px solid #f0f0f0;
				text-align: center;
				background-color: #fafafa;
			}

			.footer p {
				font-size: 12px;
				color: #bbbbbb;
				line-height: 1.8;
			}

			.footer a {
				color: #e50914;
				text-decoration: none;
				font-weight: 500;
			}
		</style>
	</head>
	<body>
		<div class="container">
			<!-- Header -->
			<div class="header">
				<div class="logo"><span class="cine">Cine</span><span class="tube">Tube</span></div>
				<div class="tagline">Email Verification</div>
			</div>

			<!-- Body -->
			<div class="body">
				<h2>Hey <%= name %>, verify your email</h2>
				<p class="desc">
					Thanks for signing up on CineTube. Use the one-time password below to verify your email address and activate
					your account.
				</p>

				<!-- OTP Box -->
				<div class="otp-box">
					<div class="otp-label">One-time password</div>

					<!-- table layout for email client compatibility -->
					<!-- OTP single field -->
					<table cellpadding="0" cellspacing="0" border="0" style="margin: 0 auto">
						<tr>
							<td>
								<div
									style="
										background: #ffffff;
										border: 1px solid #e0e0e0;
										border-radius: 8px;
										font-size: 32px;
										font-weight: 500;
										color: #e50914;
										text-align: center;
										padding: 14px 32px;
										letter-spacing: 12px;
										font-family: &quot;Segoe UI&quot;, Tahoma, Geneva, Verdana, sans-serif;
									"
								>
									<%= otp %>
								</div>
							</td>
						</tr>
					</table>

					<div class="otp-expiry">Expires in <span>2 minutes</span></div>
				</div>

				<!-- Warning -->
				<div class="warning">
					<p>Never share this OTP with anyone. CineTube will never ask for your OTP via phone or chat.</p>
				</div>

				<p class="ignore-text">If you did not create an account, you can safely ignore this email.</p>
			</div>

			<!-- Footer -->
			<div class="footer">
				<p>
					&copy; <%= new Date().getFullYear() %> CineTube. All rights reserved.<br />
					<a href="#">Privacy Policy</a> &nbsp;·&nbsp; <a href="#">Terms of Service</a>
				</p>
			</div>
		</div>
	</body>
</html>
