<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Invoice - CineTube</title>
</head>
<body style="margin:0;padding:0;background-color:#f4f4f4;font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;">

  <table width="100%" cellpadding="0" cellspacing="0" border="0">
    <tr>
      <td align="center" style="padding:40px 20px;">

        <table width="600" cellpadding="0" cellspacing="0" border="0" style="background-color:#ffffff;border-radius:16px;overflow:hidden;border:1px solid #e0e0e0;">

          <!-- Header -->
          <tr>
            <td align="center" style="padding:28px 40px 20px;border-bottom:1px solid #f0f0f0;">
              <p style="margin:0;font-size:26px;font-weight:500;letter-spacing:1px;">
                <span style="color:#1a1a1a;">Cine</span><span style="color:#e50914;">Tube</span>
              </p>
              <p style="margin:6px 0 0;font-size:11px;letter-spacing:3px;text-transform:uppercase;color:#999999;">Payment Invoice</p>
            </td>
          </tr>

          <!-- Success Badge -->
          <tr>
            <td style="padding:24px 40px 0;">
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#f0fdf4;border:1px solid #bbf7d0;border-radius:8px;">
                <tr>
                  <td style="padding:16px 20px;">
                    <table cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="width:36px;height:36px;background-color:#22c55e;border-radius:50%;text-align:center;vertical-align:middle;">
                          <span style="color:#ffffff;font-size:18px;font-weight:bold;">✓</span>
                        </td>
                        <td style="padding-left:12px;">
                          <p style="margin:0;font-size:14px;font-weight:500;color:#15803d;">Payment Successful</p>
                          <p style="margin:2px 0 0;font-size:12px;color:#16a34a;">Your transaction has been completed</p>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="padding:28px 40px;">

              <p style="margin:0 0 8px;font-size:16px;font-weight:500;color:#1a1a1a;">Hey <%= userName %>,</p>
              <p style="margin:0 0 28px;font-size:14px;color:#666666;line-height:1.7;">
                Thank you for your purchase on CineTube! Your payment has been processed successfully.
                Please find your invoice details below.
              </p>

              <!-- Info Grid -->
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:24px;">
                <tr>
                  <td width="48%" style="background-color:#fafafa;border:1px solid #e8e8e8;border-radius:10px;padding:16px;">
                    <p style="margin:0 0 6px;font-size:11px;text-transform:uppercase;letter-spacing:1.5px;color:#aaaaaa;font-weight:500;">Invoice ID</p>
                    <p style="margin:0;font-size:12px;color:#1a1a1a;font-weight:500;word-break:break-all;"><%= invoiceId %></p>
                  </td>
                  <td width="4%"></td>
                  <td width="48%" style="background-color:#fafafa;border:1px solid #e8e8e8;border-radius:10px;padding:16px;">
                    <p style="margin:0 0 6px;font-size:11px;text-transform:uppercase;letter-spacing:1.5px;color:#aaaaaa;font-weight:500;">Payment Date</p>
                    <p style="margin:0;font-size:13px;color:#1a1a1a;font-weight:500;"><%= paymentDate %></p>
                  </td>
                </tr>
                <tr><td colspan="3" style="height:12px;"></td></tr>
                <tr>
                  <td width="48%" style="background-color:#fafafa;border:1px solid #e8e8e8;border-radius:10px;padding:16px;">
                    <p style="margin:0 0 6px;font-size:11px;text-transform:uppercase;letter-spacing:1.5px;color:#aaaaaa;font-weight:500;">Transaction ID</p>
                    <p style="margin:0;font-size:11px;color:#1a1a1a;font-weight:500;word-break:break-all;"><%= transactionId %></p>
                  </td>
                  <td width="4%"></td>
                  <td width="48%" style="background-color:#fafafa;border:1px solid #e8e8e8;border-radius:10px;padding:16px;">
                    <p style="margin:0 0 6px;font-size:11px;text-transform:uppercase;letter-spacing:1.5px;color:#aaaaaa;font-weight:500;">Purchase Type</p>
                    <p style="margin:0;font-size:13px;color:#1a1a1a;font-weight:500;"><%= purchaseType %></p>
                  </td>
                </tr>
              </table>

              <!-- Purchase Summary -->
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#fafafa;border:1px solid #e8e8e8;border-radius:10px;overflow:hidden;margin-bottom:24px;">
                <tr>
                  <td colspan="2" style="padding:14px 20px;border-bottom:1px solid #e8e8e8;">
                    <p style="margin:0;font-size:12px;font-weight:500;letter-spacing:1.5px;text-transform:uppercase;color:#888888;">Purchase Summary</p>
                  </td>
                </tr>

                <% if (planType) { %>
                <tr style="border-bottom:1px solid #f0f0f0;">
                  <td style="padding:14px 20px;font-size:13px;color:#666666;">Plan</td>
                  <td style="padding:14px 20px;font-size:13px;color:#1a1a1a;font-weight:500;text-align:right;"><%= planType %></td>
                </tr>
                <% } %>

                <% if (movieTitle) { %>
                <tr style="border-bottom:1px solid #f0f0f0;">
                  <td style="padding:14px 20px;font-size:13px;color:#666666;">Movie</td>
                  <td style="padding:14px 20px;font-size:13px;color:#1a1a1a;font-weight:500;text-align:right;"><%= movieTitle %></td>
                </tr>
                <% } %>

                <tr style="background-color:#f5f5f5;">
                  <td style="padding:14px 20px;font-size:14px;font-weight:500;color:#1a1a1a;">Total Amount</td>
                  <td style="padding:14px 20px;font-size:16px;font-weight:700;color:#e50914;text-align:right;">৳<%= amount.toFixed(2) %></td>
                </tr>
              </table>

              <!-- Download Button -->
              <% if (invoiceUrl) { %>
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:24px;">
                <tr>
                  <td align="center">
                    <a href="<%= invoiceUrl %>" style="display:inline-block;background-color:#e50914;color:#ffffff;text-decoration:none;padding:14px 32px;border-radius:8px;font-size:14px;font-weight:500;">
                      Download Invoice PDF
                    </a>
                  </td>
                </tr>
              </table>
              <% } %>

              <!-- Access Info -->
              <% if (purchaseType === 'SUBSCRIPTION' && subscriptionEndsAt) { %>
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:24px;">
                <tr>
                  <td style="border-left:3px solid #d4a017;background-color:#fffbf0;border-radius:0 8px 8px 0;padding:14px 18px;">
                    <p style="margin:0;font-size:13px;color:#7a6010;line-height:1.6;">
                      Your subscription is active until <strong><%= subscriptionEndsAt %></strong>. Enjoy unlimited access to all premium content on CineTube.
                    </p>
                  </td>
                </tr>
              </table>
              <% } %>

              <% if (purchaseType === 'RENT' && rentExpiresAt) { %>
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:24px;">
                <tr>
                  <td style="border-left:3px solid #d4a017;background-color:#fffbf0;border-radius:0 8px 8px 0;padding:14px 18px;">
                    <p style="margin:0;font-size:13px;color:#7a6010;line-height:1.6;">
                      Your rental access for <strong><%= movieTitle %></strong> expires on <strong><%= rentExpiresAt %></strong>. Enjoy watching!
                    </p>
                  </td>
                </tr>
              </table>
              <% } %>

              <% if (purchaseType === 'BUY') { %>
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:24px;">
                <tr>
                  <td style="border-left:3px solid #d4a017;background-color:#fffbf0;border-radius:0 8px 8px 0;padding:14px 18px;">
                    <p style="margin:0;font-size:13px;color:#7a6010;line-height:1.6;">
                      You now have <strong>lifetime access</strong> to <strong><%= movieTitle %></strong>. Enjoy watching anytime!
                    </p>
                  </td>
                </tr>
              </table>
              <% } %>

              <p style="margin:0;font-size:13px;color:#aaaaaa;line-height:1.6;">
                If you did not make this purchase, please contact us immediately at support@cinetube.com.
              </p>

            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td align="center" style="padding:16px 40px;border-top:1px solid #f0f0f0;background-color:#fafafa;">
              <p style="margin:0;font-size:12px;color:#bbbbbb;line-height:1.8;">
                &copy; <%= new Date().getFullYear() %> CineTube. All rights reserved.<br/>
                <a href="#" style="color:#e50914;text-decoration:none;font-weight:500;">Privacy Policy</a>
                &nbsp;·&nbsp;
                <a href="#" style="color:#e50914;text-decoration:none;font-weight:500;">Terms of Service</a>
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>

</body>
</html>